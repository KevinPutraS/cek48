{
  "name": "neon48-quota-monitor",
  "private": true,
  "version": "5.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "node scripts/validate-project.mjs && node scripts/audit-identifiers.mjs && npm run lint && npm run format:check && npm run test:unit && vite build",
    "check:full": "npm run check && npm run test:e2e",
    "test": "npm run test:unit",
    "test:unit": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --project=chromium-mobile",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "vite": "^6.0.5"
  }
}
